# Shopify app credentials (Dev Dashboard → app → Client credentials)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_API_VERSION=2026-04

# The store (used by background jobs to resolve the offline token)
SHOP=cinegearpro.myshopify.com

# Public URL of this app (Railway URL) — used for webhook callbacks
APP_URL=

# Postgres (Railway injects DATABASE_URL automatically when linked)
DATABASE_URL=

# Where to persist the exchanged offline token (mount a Railway volume here)
DATA_DIR=/data

# Daily snapshot hour (UTC)
SNAPSHOT_HOUR=3
